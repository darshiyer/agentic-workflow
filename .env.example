# Optional: OpenAI for best extraction/policy reasoning quality
OPENAI_API_KEY=sk-...

# Optional: Ollama local LLM (must be running externally or in a companion container)
OLLAMA_MODEL=llama3.1

# Backend config
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Set to true to rebuild Chroma index on every startup (useful during development)
REBUILD_INDEX=false
